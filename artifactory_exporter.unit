# -*- mode: conf -*-

[Unit]
Description=Prometheus exporter for JFrog Artifactory stats.
Documentation=https://github.com/peimanja/artifactory_exporter
After=network.target

[Service]
EnvironmentFile=-/etc/default/artifactory_exporter
User=prometheus
ExecStart=/usr/bin/artifactory_exporter $ARTIFACTORY_EXPORTER_OPTS
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5s


[Install]
WantedBy=multi-user.target
