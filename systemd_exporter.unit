# -*- mode: conf -*-

[Unit]
Description=Prometheus exporter for systemd units, written in Go.
Documentation=https://github.com/prometheus-community/systemd_exporter
After=network.target

[Service]
EnvironmentFile=-/etc/default/systemd_exporter
User=prometheus
ExecStart=/usr/bin/systemd_exporter $SYSTEMD_EXPORTER_OPTS
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5s


[Install]
WantedBy=multi-user.target
